{
  "manifest_version": 3,
  "name": "Bili小尾巴 VRC解析",
  "version": "0.6.1",
  "description": "摇摇小尾巴，把B站视频轻轻变成VRC播放链接，一键复制带去世界里用。",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "contextMenus",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://api.bilibili.com/*",
    "https://api.live.bilibili.com/*",
    "https://music.znnu.com/*"
  ],
  "action": {
    "default_title": "Bili小尾巴 VRC解析",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
