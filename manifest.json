{
  "manifest_version": 3,
  "name": "Bili小尾巴 VRC弹幕版",
  "version": "0.2.0",
  "description": "实验版小尾巴：把B站视频变成VRC可用链接，也能连接自己的后端生成带弹幕HLS。",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "contextMenus",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://api.bilibili.com/*",
    "https://api.live.bilibili.com/*"
  ],
  "action": {
    "default_title": "Bili小尾巴 VRC弹幕版",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
